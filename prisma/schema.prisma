// Modelo de datos — Cuidado Mataró (marketplace de tres lados)
// Base de datos: PostgreSQL (compatible con Supabase).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // usado por Supabase para migraciones (pooler vs directo)
}

// ─────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────

enum Role {
  FAMILIA
  CUIDADORA
  ADMIN
}

enum PlanKey {
  // Planes de ACCESO a la plataforma (modelo actual): dos niveles para familias.
  BASICO // 29,99 €/mes · contactos limitados (PLAN_BASICO_CONTACTOS)
  COMPLETO // 69 €/mes · más contactos (PLAN_COMPLETO_CONTACTOS)
  // Legacy — conservados por compatibilidad, sin uso:
  ACCESO // cuota única anterior (69 €)
  TRANQUILIDAD
  HOGAR
}

enum SubscriptionStatus {
  INCOMPLETE // checkout iniciado, aún sin pagar
  ACTIVE // pago al día → acceso a reservar
  PAST_DUE // impago → acceso restringido
  CANCELED // dada de baja
}

enum ShiftStatus {
  PENDIENTE // buscando cuidadora
  CONFIRMADO // una cuidadora la aceptó
  COMPLETADO // visita realizada
  CANCELADO
}

enum DayType {
  LABORABLE // lunes-viernes
  SABADO
  DOMINGO
}

enum HourSource {
  PLAN // descontada de la bolsa mensual
  EXTRA // pagada como hora suelta
}

enum ResponseAction {
  ACEPTADO
  RECHAZADO
}

enum PaymentType {
  SUSCRIPCION
  HORAS_EXTRA
}

enum PaymentStatus {
  PENDIENTE
  PAGADO
  FALLIDO
  REEMBOLSADO
}

// ─────────────────────────────────────────────
//  USUARIOS Y PERFILES
// ─────────────────────────────────────────────

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String
  phone        String?
  role         Role    @default(FAMILIA)

  // Consentimiento RGPD explícito (datos de salud)
  consentRGPD Boolean   @default(false)
  consentAt   DateTime?

  stripeCustomerId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones (FAMILIA)
  careRecipients CareRecipient[]
  subscriptions  Subscription[]
  payments       Payment[]
  extraPurchases ExtraHoursPurchase[]
  shiftsAsFamily Shift[]              @relation("FamilyShifts")

  // Relaciones (CUIDADORA)
  caregiverProfile  CaregiverProfile?
  shiftsAsCaregiver Shift[]           @relation("CaregiverShifts")
  shiftResponses    ShiftResponse[]

  // Mensajería
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model CaregiverProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  zones        String[] // municipios donde trabaja (Mataró, Argentona, Premià…)
  availability Json? // disponibilidad semanal { lun: ["09:00-13:00"], ... }
  bio          String?
  training     String? // formación / titulación
  photoUrl     String?

  // Tarifa por hora que fija LIBREMENTE la propia cuidadora (rango desde/hasta, en céntimos).
  // Opcional: si no la define, se muestra "a convenir". La plataforma NO fija ninguna tarifa.
  hourlyRateMinCents Int?
  hourlyRateMaxCents Int?

  hourlyPayCents Int    @default(1400) // LEGACY (modelo agencia): sin uso

  verified   Boolean   @default(false) // verificada por el admin
  verifiedAt DateTime?
  suspended  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
//  PERSONAS A CUIDAR (datos de salud — cifrados)
// ─────────────────────────────────────────────

model CareRecipient {
  id           String @id @default(cuid())
  familyUserId String
  family       User   @relation(fields: [familyUserId], references: [id], onDelete: Cascade)

  name String
  age  Int?

  zone String // municipio (visible para emparejar turnos): "Mataró", "Argentona"…

  // Campos sensibles cifrados (AES-256-GCM) — ver src/lib/encryption.ts
  addressEnc String? // dirección completa cifrada
  needsEnc   String? // necesidades / datos de salud cifrados
  notesEnc   String? // notas cifradas

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts Shift[]
}

// ─────────────────────────────────────────────
//  PLANES Y SUSCRIPCIONES
// ─────────────────────────────────────────────

// En el modelo plataforma existe un único Plan: ACCESO (cuota mensual de acceso).
// `monthlyHours` se conserva por compatibilidad pero queda a 0 (sin bolsa de horas).
model Plan {
  id           String  @id @default(cuid())
  key          PlanKey @unique
  name         String
  monthlyHours Int     @default(0) // LEGACY: sin uso en el modelo plataforma
  priceCents   Int
  stripePriceId String?

  subscriptions Subscription[]
}

model Subscription {
  id           String @id @default(cuid())
  familyUserId String
  family       User   @relation(fields: [familyUserId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  stripeSubscriptionId String? @unique
  status               SubscriptionStatus @default(INCOMPLETE)

  hoursIncluded     Int @default(0) // LEGACY: sin uso en el modelo plataforma (sin bolsa de horas)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime? // fin del ciclo de la cuota de acceso (renovación mensual)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([familyUserId])
}

// LEGACY (modelo agencia): compra de horas sueltas. Sin uso en el modelo plataforma;
// se conserva la tabla por histórico, pero no hay flujo que la cree.
model ExtraHoursPurchase {
  id           String @id @default(cuid())
  familyUserId String
  family       User   @relation(fields: [familyUserId], references: [id], onDelete: Cascade)

  hours          Float
  pricePerHourCents Int
  totalCents     Int
  dayType        DayType

  stripePaymentIntentId String?
  status                PaymentStatus @default(PENDIENTE)

  createdAt DateTime @default(now())

  @@index([familyUserId])
}

// ─────────────────────────────────────────────
//  TURNOS / RESERVAS (el corazón del marketplace)
// ─────────────────────────────────────────────

model Shift {
  id String @id @default(cuid())

  careRecipientId String
  careRecipient   CareRecipient @relation(fields: [careRecipientId], references: [id], onDelete: Cascade)

  familyUserId String
  family       User   @relation("FamilyShifts", fields: [familyUserId], references: [id], onDelete: Cascade)

  caregiverUserId String?
  caregiver       User?   @relation("CaregiverShifts", fields: [caregiverUserId], references: [id])

  // Programación
  start         DateTime
  end           DateTime
  durationHours Float
  dayType       DayType
  zone          String // municipio (visible para todas las cuidadoras)

  // Dirección completa SOLO visible tras aceptar el turno (se rellena al confirmar).
  // Mientras tanto la cuidadora ve solo `zone`.
  addressEnc String? // copia cifrada de la dirección, accesible tras aceptar

  status ShiftStatus @default(PENDIENTE)

  // LEGACY (modelo agencia): contabilidad de bolsa de horas. Sin uso, siempre 0.
  hoursFromPlan  Float @default(0)
  hoursFromExtra Float @default(0)

  // Tarifa de referencia del cuidado para este turno (informativa).
  // La plataforma NO la cobra: se acuerda y abona directamente entre familia y cuidadora.
  caregiverPayCents Int @default(0)

  // Aceptación voluntaria (modelo plataforma, no laboral)
  acceptedAt          DateTime?
  acceptanceVoluntary Boolean   @default(false)

  // Gestión de alertas (admin)
  alertDeadline DateTime? // si no se cubre antes de esta hora → alerta
  alertedAdmin  Boolean   @default(false)

  // Resumen de cuidados seguro de mostrar (sin datos médicos sensibles)
  careSummary String?

  completedAt DateTime?
  canceledAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses ShiftResponse[]
  messages  Message[]

  @@index([status])
  @@index([zone])
  @@index([familyUserId])
  @@index([caregiverUserId])
}

// Registro de cada aceptación/rechazo (deja constancia de voluntariedad)
model ShiftResponse {
  id      String @id @default(cuid())
  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  caregiverUserId String
  caregiver       User   @relation(fields: [caregiverUserId], references: [id], onDelete: Cascade)

  action    ResponseAction
  voluntary Boolean        @default(true)
  createdAt DateTime       @default(now())

  @@index([shiftId])
  @@index([caregiverUserId])
}

// ─────────────────────────────────────────────
//  PAGOS Y MENSAJES
// ─────────────────────────────────────────────

model Payment {
  id           String @id @default(cuid())
  familyUserId String
  family       User   @relation(fields: [familyUserId], references: [id], onDelete: Cascade)

  type          PaymentType
  amountCents   Int
  status        PaymentStatus @default(PENDIENTE)
  description   String?
  stripeRef     String? // payment_intent o invoice id

  createdAt DateTime @default(now())

  @@index([familyUserId])
}

model Message {
  id      String  @id @default(cuid())
  shiftId String?
  shift   Shift?  @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  senderUserId    String
  sender          User   @relation("SentMessages", fields: [senderUserId], references: [id], onDelete: Cascade)
  recipientUserId String
  recipient       User   @relation("ReceivedMessages", fields: [recipientUserId], references: [id], onDelete: Cascade)

  body   String
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([shiftId])
  @@index([recipientUserId])
}
